  "keyFeatures": [
    "Daily player shop with skin previews and prices",
    "Night Market with discounted skin offers",
    "Current bundle browsing with full skin details",
    "Skin gallery with search and filtering",
    "Wishlist with push notifications when wished skins appear in shop",
    "Background notifications for store renewal, night market, and bundles",
    "Player account info including wallet balances and account level",
    "Player loadout and equipped skin viewer",
    "Riot Games SSO login via in-app WebView",
    "Firebase-backed skin database and wishlist persistence"
  ],
