{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Valstore",
  "theme": "almond",
  "colors": {
    "primary": "#f84555",
    "light": "#962d36",
    "dark": "#f84555"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/ruzbyte/valstore-mobile"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ruzbyte/valstore-mobile"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "getting-started/installation", "getting-started/login"]
          },
          {
            "group": "Features",
            "pages": [
              "features/player-shop",
              "features/night-market",
              "features/bundles",
              "features/gallery",
              "features/wishlist",
              "features/notifications"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "account/inventory",
              "account/loadout",
              "account/settings"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/common-issues",
              "troubleshooting/notifications"
            ]
          }
        ]
      },
      {
        "tab": "Developer Guide",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
              "dev/overview",
              "dev/services",
              "dev/models"
            ]
          },
          {
            "group": "APIs",
            "pages": [
              "dev/riot-api",
              "dev/valorant-api",
              "dev/firebase"
            ]
          },
          {
            "group": "Contributing",
            "pages": [
              "dev/setup",
              "dev/contributing"
            ]
          }
        ]
      }
    ]
  }
}
